# Copy this file to `.env` at the project root and fill in real values.
# Do NOT commit your real `.env` (it's already gitignored).

# ---- Django core ----
# Secret key for cryptographic signing. REQUIRED in production.
# Generate one with: python -c "import secrets;print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string

# `true` in development, `false` in production.
DEBUG=true

# Comma-separated list of hostnames the site is allowed to serve.
# Render injects RENDER_EXTERNAL_HOSTNAME automatically; Vercel injects VERCEL_URL.
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Comma-separated list of trusted CSRF origins, e.g. https://www.example.com
CSRF_TRUSTED_ORIGINS=

# ---- Database ----
# Postgres connection string. Leave UNSET to fall back to a local sqlite file
# (./db.sqlite3) — handy for local dev and testing.
DATABASE_URL=postgres://user:password@localhost:5432/aportfolio

# ---- Channels / Redis ----
# Redis URL for django-channels. Leave unset to use the in-memory layer.
REDIS_URL=redis://localhost:6379

# Symmetric key for encrypted channel layer messages.
ENCRYPTION_KEY=change-me
