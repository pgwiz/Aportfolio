# Copy this file to `.env` at the project root and fill in real values.
# Do NOT commit your real `.env` (it's already gitignored).

# Postgres connection string used by portfolio_project/settings.py
DATABASE_URL=postgres://user:password@localhost:5432/aportfolio

# Redis URL used by django-channels (and any direct Redis usage)
REDIS_URL=redis://localhost:6379

# Symmetric key for encrypted channel layer messages.
# Generate something random for production, e.g. `python -c "import secrets;print(secrets.token_urlsafe(48))"`.
ENCRYPTION_KEY=change-me
